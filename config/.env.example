# Copy to config/.env (not committed) and set for your environment.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=

# Show PHP errors in the browser (disable in production when stable)
# APP_DEBUG=1

# Use in-memory dummy data when MySQL is unavailable or for UI-only dev
# DEV_MOCK=1

# Optional: require ?key=... to open dbStatus.php (connection diagnostics)
# DIAG_KEY=changeme
