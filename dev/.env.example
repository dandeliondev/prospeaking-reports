# Copy to dev/.env on the server (same folder as this repo) for local overrides.
# DB_PASS=          # leave empty if root has no password
# DEV_MOCK=1        # force dummy data (no MySQL)
# APP_DEBUG=1       # show PHP errors on screen (turn off in production when stable)

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=

# Uncomment to always use in-memory dummy data:
# DEV_MOCK=1
